---
# GHCR push credentials for buildah
# The buildah task expects a docker-registry type secret with .dockerconfigjson
#
# Create with:
#   oc create secret docker-registry ghcr-credentials -n liberty-apps \
#     --docker-server=ghcr.io \
#     --docker-username=jconover \
#     --docker-password=<GITHUB_PAT>
#
# The PAT needs write:packages scope.

---
# Git credentials for cloning and committing updated image tags
# The git-clone task (Pipelines v1.21+) expects .git-credentials and .gitconfig files
#
# Create with:
#   oc create secret generic git-credentials -n liberty-apps \
#     --from-literal=.git-credentials="https://jconover:<GITHUB_PAT>@github.com" \
#     --from-literal=.gitconfig='[credential "https://github.com"]
#       helper = store'
#
# The PAT needs repo/contents:write scope.
