---
# GHCR push credentials for buildah
# Replace <GITHUB_PAT> with a personal access token that has write:packages scope
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-credentials
  namespace: liberty-apps
  annotations:
    tekton.dev/docker-0: https://ghcr.io
type: kubernetes.io/basic-auth
stringData:
  username: jconover
  password: <GITHUB_PAT>
---
# Git credentials for committing updated image tags back to the repo
# Replace <GITHUB_PAT> with a token that has repo/contents:write scope
apiVersion: v1
kind: Secret
metadata:
  name: git-credentials
  namespace: liberty-apps
  annotations:
    tekton.dev/git-0: https://github.com
type: kubernetes.io/basic-auth
stringData:
  username: jconover
  password: <GITHUB_PAT>
