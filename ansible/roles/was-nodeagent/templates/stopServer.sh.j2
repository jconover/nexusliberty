#!/usr/bin/env bash
# {{ ansible_managed }}
# Mock stopServer.sh — simulates stopping a WAS application server

SERVER=${1:-{{ was_server_name }}}
PROFILE_HOME="{{ was_profile_path }}"
LOG_FILE="{{ was_log_dir }}/stopServer.log"

echo "ADMU0116I: Tool information is being logged in ${LOG_FILE}"
echo "ADMU0128I: Starting tool with the {{ was_profile_name }} profile"
echo "ADMU4000I: Server ${SERVER} stop completed"

echo "STOPPED $(date -Iseconds)" > "${PROFILE_HOME}/.${SERVER}.state"
