#!/usr/bin/env bash
# {{ ansible_managed }}
# Mock stopNode.sh — simulates stopping the WAS node agent

PROFILE_HOME="{{ was_profile_path }}"
LOG_FILE="{{ was_log_dir }}/stopNode.log"

echo "ADMU0116I: Tool information is being logged in ${LOG_FILE}"
echo "ADMU0128I: Starting tool with the {{ was_profile_name }} profile"
echo "ADMU4000I: Server nodeagent stop completed on {{ was_node_name }}"

echo "STOPPED $(date -Iseconds)" > "${PROFILE_HOME}/.nodeagent.state"
