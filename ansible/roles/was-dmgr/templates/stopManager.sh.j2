#!/usr/bin/env bash
# {{ ansible_managed }}
# Mock stopManager.sh — simulates stopping the WAS Deployment Manager

PROFILE_HOME="{{ was_profile_path }}"
LOG_FILE="{{ was_log_dir }}/stopManager.log"

echo "ADMU0116I: Tool information is being logged in ${LOG_FILE}"
echo "ADMU0128I: Starting tool with the Dmgr01 profile"
echo "ADMU4000I: Server dmgr stop completed"

# Record state
echo "STOPPED $(date -Iseconds)" > "${PROFILE_HOME}/.dmgr.state"
