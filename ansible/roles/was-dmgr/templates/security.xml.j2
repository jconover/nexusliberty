<?xml version="1.0" encoding="UTF-8"?>
<!-- {{ ansible_managed }} -->
<!-- WAS Administrative Security Configuration -->
<security:Security enabled="true"
                   cacheTimeout="600"
                   enforceJava2Security="false"
                   appEnabled="true"
                   xmlns:security="http://www.ibm.com/websphere/appserver/schemas/5.0/security.xmi">

  <userRegistries type="LocalOS"
                  serverId="{{ was_admin_user }}"
                  serverPassword="{xor}encoded_password_placeholder"
                  realm="defaultWIMFileBasedRealm"/>

  <authMechanisms type="LTPA"
                  timeout="120"
                  OID="oid:1.3.18.0.2.30.2"/>

</security:Security>
