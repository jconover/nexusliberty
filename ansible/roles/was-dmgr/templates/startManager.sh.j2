# Mock startManager.sh — simulates starting the WAS Deployment Manager

PROFILE_HOME="{{ was_profile_path }}"
LOG_FILE="{{ was_log_dir }}/startManager.log"

echo "ADMU0116I: Tool information is being logged in ${LOG_FILE}"
